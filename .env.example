# Database connection string.
#
# Recommended: Prisma Postgres + Accelerate (paste the URL from the Prisma
# Console at https://console.prisma.io). It looks like:
#   prisma+postgres://accelerate.prisma-data.net/?api_key=...
#
# Alternative: any Postgres URL works (Neon, Supabase, local, etc.):
#   postgresql://user:password@host/db?sslmode=require
DATABASE_URL=""

# OpenAI API key for LLM extraction (or any OpenAI-compatible provider key)
OPENAI_API_KEY="sk-..."

# Optional: point the extractor at an OpenAI-compatible proxy.
# Examples:
#   Poe       -> https://api.poe.com/v1
#   Groq      -> https://api.groq.com/openai/v1
#   Together  -> https://api.together.xyz/v1
# Leave unset to use the default https://api.openai.com/v1.
OPENAI_BASE_URL=""

# Optional: override the default model. When using a proxy like Poe, set this
# to a model the proxy supports (e.g. "GPT-4.1-mini" or "Claude-Haiku-4").
OPENAI_EXTRACT_MODEL="gpt-4.1-mini"

# Ticketmaster Discovery API consumer key. Free tier is 5,000 requests/day
# (https://developer.ticketmaster.com/). Required to enable the
# `ticketmaster` adapter; without it that source returns an error and the
# rest of the matrix is unaffected.
TICKETMASTER_API_KEY=""

# Shared secret for the cron route. Vercel Cron sends this in the Authorization header.
CRON_SECRET="generate-a-long-random-string"

# Google Maps API key. Grab a free one at https://console.cloud.google.com/maps-apis.
GOOGLE_MAPS_API_KEY=""

# Optional: Straz Center (strazcenter.org) is often protected by Incapsula. After
# opening the site in a normal browser, copy the full `Cookie` request header
# for a request to strazcenter.org and paste it here (rotate when it expires).
# Without this, the straz_center adapter may return 0 listing URLs.
STRAZCENTER_SCRAPE_COOKIE=""