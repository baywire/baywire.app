// Baywire — Prisma schema.
//
// Database:  Prisma Postgres (managed)
// Pooler:    Prisma Accelerate (set DATABASE_URL to the prisma+postgres:// URL)
// Schema:    All Baywire tables live in the `baywire` Postgres schema.
//
// To apply this schema after editing:
//   npm run db:push          # dev: shove schema into DB without a migration
//   npm run db:migrate:dev   # dev: generate + apply a migration
//   npm run db:migrate       # prod: apply existing migrations

// Prisma 7: connection URL lives in `prisma.config.ts`, not here.
// The `datasource` block declares the database flavor and the schema(s) Prisma
// is allowed to manage.
generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  schemas  = ["baywire"]
}

enum TicketStatus {
  on_sale
  sold_out
  not_yet
  cancelled
  free
  rsvp
  unknown

  @@schema("baywire")
}

enum City {
  tampa
  st_petersburg
  clearwater
  brandon
  bradenton
  safety_harbor
  dunedin
  other

  @@schema("baywire")
}

model Source {
  id         String    @id @default(uuid()) @db.Uuid
  slug       String    @unique
  label      String
  baseUrl    String    @map("base_url")
  enabled    Boolean   @default(true)
  lastRunAt  DateTime? @map("last_run_at") @db.Timestamptz()
  lastStatus String?   @map("last_status")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  scrapeRuns ScrapeRun[]
  events     Event[]
  places     Place[]

  @@map("sources")
  @@schema("baywire")
}

model ScrapeRun {
  id             String    @id @default(uuid()) @db.Uuid
  sourceId       String    @map("source_id") @db.Uuid
  startedAt      DateTime  @default(now()) @map("started_at") @db.Timestamptz()
  finishedAt     DateTime? @map("finished_at") @db.Timestamptz()
  eventsSeen     Int       @default(0) @map("events_seen")
  eventsInserted Int       @default(0) @map("events_inserted")
  eventsUpdated  Int       @default(0) @map("events_updated")
  eventsSkipped  Int       @default(0) @map("events_skipped")
  error          String?

  source  Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  aiUsage AiUsage[]

  @@index([sourceId, startedAt], map: "scrape_runs_source_started_idx")
  @@map("scrape_runs")
  @@schema("baywire")
}

model Event {
  id             String        @id @default(uuid()) @db.Uuid
  canonicalId    String?       @map("canonical_id") @db.Uuid
  sourceId       String        @map("source_id") @db.Uuid
  sourceEventId  String        @map("source_event_id")
  title          String
  description    String?
  startAt        DateTime      @map("start_at") @db.Timestamptz()
  endAt          DateTime?     @map("end_at") @db.Timestamptz()
  allDay         Boolean       @default(false) @map("all_day")
  venueName      String?       @map("venue_name")
  address        String?
  city           City          @default(other)
  lat            Float?
  lng            Float?
  priceMin       Decimal?      @map("price_min") @db.Decimal(10, 2)
  priceMax       Decimal?      @map("price_max") @db.Decimal(10, 2)
  isFree         Boolean       @default(false) @map("is_free")
  ticketUrl      String?       @map("ticket_url")
  ticketStatus   TicketStatus? @map("ticket_status")
  ticketCurrency String?       @map("ticket_currency")
  onSaleAt       DateTime?     @map("on_sale_at") @db.Timestamptz()
  validFromAt    DateTime?     @map("valid_from_at") @db.Timestamptz()
  priceTiers     Json?         @map("price_tiers")
  categories     String[]      @default([])
  imageUrl       String?       @map("image_url")
  eventUrl       String        @map("event_url")
  contentHash    String        @map("content_hash")
  lastSeenAt     DateTime      @default(now()) @map("last_seen_at") @db.Timestamptz()
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  canonical CanonicalEvent? @relation("EventCanonicalGroup", fields: [canonicalId], references: [id], onDelete: SetNull)
  primaryOf CanonicalEvent? @relation("CanonicalPrimaryEvent")
  source    Source          @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, sourceEventId], map: "events_source_source_event_id_uidx")
  @@index([canonicalId], map: "events_canonical_id_idx")
  @@index([startAt], map: "events_start_at_idx")
  @@index([city, startAt], map: "events_city_start_at_idx")
  @@index([isFree, startAt], map: "events_is_free_start_at_idx")
  @@index([ticketStatus, startAt], map: "events_ticket_status_start_at_idx")
  @@map("events")
  @@schema("baywire")
}

model CanonicalEvent {
  id                 String    @id @default(uuid()) @db.Uuid
  primaryEventId     String?   @unique @map("primary_event_id") @db.Uuid
  dedupedTitle       String?   @map("deduped_title")
  summary            String?
  vibes              String[]  @default([])
  audience           String?
  indoorOutdoor      String?   @map("indoor_outdoor")
  tags               String[]  @default([])
  whyItsCool         String?   @map("why_its_cool")
  editorialScore     Float?    @map("editorial_score")
  editorialHash      String?   @map("editorial_hash")
  editorialUpdatedAt DateTime? @map("editorial_updated_at") @db.Timestamptz()
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  primaryEvent Event?  @relation("CanonicalPrimaryEvent", fields: [primaryEventId], references: [id], onDelete: SetNull)
  events       Event[] @relation("EventCanonicalGroup")

  @@index([editorialScore], map: "canonical_events_editorial_score_idx")
  @@map("canonical_events")
  @@schema("baywire")
}

enum PlaceCategory {
  restaurant
  brewery
  bar
  cafe
  bakery
  museum
  gallery
  park
  beach
  shop
  venue
  attraction
  other

  @@schema("baywire")
}

model Place {
  id                 String        @id @default(uuid()) @db.Uuid
  sourceId           String        @map("source_id") @db.Uuid
  sourcePlaceId      String        @map("source_place_id")
  name               String
  slug               String        @unique
  description        String?
  category           PlaceCategory @default(other)
  city               City          @default(other)
  address            String?
  lat                Float?
  lng                Float?
  imageUrl           String?       @map("image_url")
  websiteUrl         String?       @map("website_url")
  phoneNumber        String?       @map("phone_number")
  priceRange         String?       @map("price_range")
  hoursJson          Json?         @map("hours_json")
  sourceUrl          String        @map("source_url")
  contentHash        String        @map("content_hash")
  searchType         String?       @map("search_type")
  overtureId         String?       @unique @map("overture_id")
  verified           Boolean       @default(false)
  webRating          Float?        @map("web_rating")
  webReviewCount     Int?          @map("web_review_count")
  summary            String?
  vibes              String[]      @default([])
  tags               String[]      @default([])
  whyItsCool         String?       @map("why_its_cool")
  editorialScore     Float?        @map("editorial_score")
  editorialHash      String?       @map("editorial_hash")
  editorialUpdatedAt DateTime?     @map("editorial_updated_at") @db.Timestamptz()
  lastSeenAt         DateTime      @default(now()) @map("last_seen_at") @db.Timestamptz()
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, sourcePlaceId], map: "places_source_source_place_id_uidx")
  @@index([city, category], map: "places_city_category_idx")
  @@index([editorialScore], map: "places_editorial_score_idx")
  @@map("places")
  @@schema("baywire")
}

enum MetricAction {
  add_to_plan
  remove_from_plan
  save_event
  unsave_event
  view_event
  view_place
  filter_tags
  search
  share_event
  share_plan
  open_ticket_link

  @@schema("baywire")
}

model Metric {
  id        String       @id @default(uuid()) @db.Uuid
  sessionId String       @map("session_id") @db.Uuid
  action    MetricAction
  eventId   String?      @map("event_id") @db.Uuid
  placeId   String?      @map("place_id") @db.Uuid
  payload   Json?
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  @@index([action, createdAt], map: "metrics_action_created_at_idx")
  @@index([sessionId, createdAt], map: "metrics_session_created_at_idx")
  @@index([eventId], map: "metrics_event_id_idx")
  @@map("metrics")
  @@schema("baywire")
}


enum AiFeature {
  extract_event
  extract_place
  extract_listings
  editorial_event
  editorial_place
  search_rerank

  @@schema("baywire")
}

model AiUsage {
  id               String     @id @default(uuid()) @db.Uuid
  feature          AiFeature
  model            String
  promptTokens     Int        @map("prompt_tokens")
  completionTokens Int        @map("completion_tokens")
  totalTokens      Int        @map("total_tokens")
  estimatedCostUsd Float      @map("estimated_cost_usd")
  latencyMs        Int        @map("latency_ms")
  success          Boolean    @default(true)
  error            String?
  scrapeRunId      String?    @map("scrape_run_id") @db.Uuid
  meta             Json?
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz()

  scrapeRun ScrapeRun? @relation(fields: [scrapeRunId], references: [id], onDelete: SetNull)

  @@index([feature, createdAt], map: "ai_usage_feature_created_at_idx")
  @@index([scrapeRunId], map: "ai_usage_scrape_run_id_idx")
  @@index([model, createdAt], map: "ai_usage_model_created_at_idx")
  @@map("ai_usage")
  @@schema("baywire")
}
